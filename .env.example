# Kopiere diese Datei nach .env.local und trage die Werte ein.
# Auf Vercel: Settings → Environment Variables (Projekt: macario.dev)

# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Admin — Passwort für /admin/projects (Fallback im Code: dev-secret-123)
ADMIN_SECRET=

# Optional — Microlink API-Key für Screenshot-Capture (höhere Limits)
MICROLINK_API_KEY=

# Empfohlen — Service Role Key für serverseitige Storage-Uploads
SUPABASE_SERVICE_ROLE_KEY=
